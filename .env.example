# ============================================================
# DocGen Platform - 环境变量示例文件
# 复制此文件为 .env 并修改密码
# ============================================================

COMPOSE_PROJECT_NAME=docgen
TZ=Asia/Shanghai

# PostgreSQL 应用数据库
POSTGRES_USER=docgen
POSTGRES_PASSWORD=<请修改为强密码>
POSTGRES_DB=docgen_platform

# Kong 数据库
KONG_PG_USER=kong
KONG_PG_PASSWORD=<请修改为强密码>

# Redis
REDIS_PASSWORD=<请修改为强密码>

# MinIO 对象存储
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<请修改为强密码>
MINIO_DEFAULT_BUCKET=docgen-documents

# JWT 认证
JWT_SECRET=<请修改为随机字符串>
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Euro-Office 文档编辑器
EURO_OFFICE_JWT_SECRET=<请修改为随机字符串>

# Kafka
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092

# Kong 网关
KONG_ADMIN_TOKEN=<请修改为随机字符串>

# 后端服务
NODE_ENV=production
LOG_LEVEL=info
API_RATE_LIMIT_MINUTE=100
API_RATE_LIMIT_HOUR=1000

# Nginx / SSL
SERVER_NAME=docgen.local
